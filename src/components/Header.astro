---
import ThemeToggle from './ThemeToggle.astro';
import Search from './Search.astro';
import { subcategories } from '../utils/subcategories';
import type { Category } from '../utils/categories';

interface NavItem {
  label: string;
  href: string;
  category?: Category;
}

const navItems: NavItem[] = [
  { label: '독서', href: '/reading', category: 'reading' },
  { label: '일상', href: '/essay', category: 'essay' },
  { label: '코딩', href: '/dev', category: 'dev' },
  { label: 'About', href: '/about' },
];

const currentPath = Astro.url.pathname;
---

<header class="border-b border-(--color-border) bg-(--color-bg)/80 backdrop-blur-sm sticky top-0 z-50">
  <nav class="max-w-3xl mx-auto px-4 sm:px-6 h-14 sm:h-16 flex items-center justify-between">
    <a href="/" class="text-lg sm:text-xl font-bold hover:text-(--color-accent-dev) transition-colors shrink-0">
      Ethan's Blog
    </a>

    {/* 데스크톱 네비게이션 */}
    <div class="hidden sm:flex items-center gap-1">
      {navItems.map(({ label, href, category }) => (
        category && subcategories[category] ? (
          <div class="relative group">
            <a
              href={href}
              class:list={[
                'px-3 py-2 rounded-lg text-sm font-medium transition-colors inline-flex items-center gap-1',
                currentPath.startsWith(href)
                  ? 'text-(--color-text) bg-(--color-bg-secondary)'
                  : 'text-(--color-text-secondary) hover:text-(--color-text) hover:bg-(--color-bg-secondary)',
              ]}
            >
              {label}
              <svg class="w-3 h-3 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </a>
            <div class="absolute top-full left-0 pt-1 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 z-50">
              <div class="bg-(--color-bg) border border-(--color-border) rounded-lg shadow-lg py-1 min-w-[120px]">
                <a
                  href={href}
                  class:list={[
                    'block px-4 py-2 text-sm transition-colors',
                    currentPath === href || currentPath === `${href}/`
                      ? 'text-(--color-text) bg-(--color-bg-secondary) font-medium'
                      : 'text-(--color-text-secondary) hover:text-(--color-text) hover:bg-(--color-bg-secondary)',
                  ]}
                >
                  전체
                </a>
                {subcategories[category].map((sub) => {
                  const subHref = `${href}/${sub.slug}`;
                  return (
                    <a
                      href={subHref}
                      class:list={[
                        'block px-4 py-2 text-sm transition-colors',
                        currentPath.startsWith(subHref)
                          ? 'text-(--color-text) bg-(--color-bg-secondary) font-medium'
                          : 'text-(--color-text-secondary) hover:text-(--color-text) hover:bg-(--color-bg-secondary)',
                      ]}
                    >
                      {sub.label}
                    </a>
                  );
                })}
              </div>
            </div>
          </div>
        ) : (
          <a
            href={href}
            class:list={[
              'px-3 py-2 rounded-lg text-sm font-medium transition-colors',
              currentPath.startsWith(href)
                ? 'text-(--color-text) bg-(--color-bg-secondary)'
                : 'text-(--color-text-secondary) hover:text-(--color-text) hover:bg-(--color-bg-secondary)',
            ]}
          >
            {label}
          </a>
        )
      ))}
      <Search />
      <ThemeToggle />
    </div>

    {/* 모바일 네비게이션 */}
    <div class="flex sm:hidden items-center gap-0.5">
      <Search />
      <ThemeToggle />
      <button
        id="menu-toggle"
        type="button"
        aria-label="메뉴"
        class="p-2 rounded-lg text-(--color-text-secondary) hover:text-(--color-text) hover:bg-(--color-bg-secondary) transition-colors cursor-pointer"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </nav>

  {/* 모바일 메뉴 */}
  <div id="mobile-menu" class="hidden sm:hidden border-t border-(--color-border) bg-(--color-bg)">
    <div class="max-w-3xl mx-auto px-4 py-2 flex flex-col">
      {navItems.map(({ label, href, category }) => (
        category && subcategories[category] ? (
          <div class="mobile-accordion">
            <button
              type="button"
              class:list={[
                'w-full px-3 py-2.5 rounded-lg text-sm font-medium transition-colors flex items-center justify-between cursor-pointer',
                currentPath.startsWith(href)
                  ? 'text-(--color-text) bg-(--color-bg-secondary)'
                  : 'text-(--color-text-secondary) hover:text-(--color-text) hover:bg-(--color-bg-secondary)',
              ]}
              data-accordion-toggle
            >
              {label}
              <svg class="w-3.5 h-3.5 opacity-50 transition-transform accordion-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="accordion-content hidden pl-4 pb-1">
              <a
                href={href}
                class:list={[
                  'block px-3 py-2 rounded-lg text-sm transition-colors',
                  currentPath === href || currentPath === `${href}/`
                    ? 'text-(--color-text) font-medium'
                    : 'text-(--color-text-secondary) hover:text-(--color-text)',
                ]}
              >
                전체
              </a>
              {subcategories[category].map((sub) => {
                const subHref = `${href}/${sub.slug}`;
                return (
                  <a
                    href={subHref}
                    class:list={[
                      'block px-3 py-2 rounded-lg text-sm transition-colors',
                      currentPath.startsWith(subHref)
                        ? 'text-(--color-text) font-medium'
                        : 'text-(--color-text-secondary) hover:text-(--color-text)',
                    ]}
                  >
                    {sub.label}
                  </a>
                );
              })}
            </div>
          </div>
        ) : (
          <a
            href={href}
            class:list={[
              'px-3 py-2.5 rounded-lg text-sm font-medium transition-colors',
              currentPath.startsWith(href)
                ? 'text-(--color-text) bg-(--color-bg-secondary)'
                : 'text-(--color-text-secondary) hover:text-(--color-text) hover:bg-(--color-bg-secondary)',
            ]}
          >
            {label}
          </a>
        )
      ))}
    </div>
  </div>
</header>

<script is:inline>
  document.getElementById('menu-toggle')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });
  document.querySelectorAll('[data-accordion-toggle]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const content = btn.nextElementSibling;
      const chevron = btn.querySelector('.accordion-chevron');
      if (content) content.classList.toggle('hidden');
      if (chevron) chevron.classList.toggle('rotate-180');
    });
  });
</script>
