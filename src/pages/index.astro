---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';
import { buildSlugMap } from '../utils/slugs';

const allPosts = (await getCollection('posts')).filter((p) => !p.data.draft);
const slugMap = buildSlugMap(allPosts);
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Ethan's Blog">
  <h1 class="text-3xl font-bold mb-2">Blog</h1>
  <p class="text-(--color-text-secondary) mb-8">독서, 일상, 코딩에 대한 기록</p>
  <div class="space-y-4">
    {posts.map((post) => (
      <PostCard
        title={post.data.title}
        description={post.data.description}
        category={post.data.category}
        subcategory={post.data.subcategory}
        pubDate={post.data.pubDate}
        tags={post.data.tags}
        slug={slugMap.get(post.id)!}
        body={post.body}
          heroImage={post.data.heroImage}
        bookTitle={post.data.bookTitle}
        bookAuthor={post.data.bookAuthor}
        rating={post.data.rating}
      />
    ))}
  </div>
</BaseLayout>
