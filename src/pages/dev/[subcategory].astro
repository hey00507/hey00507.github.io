---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import SubcategoryNav from '../../components/SubcategoryNav.astro';
import { getCollection } from 'astro:content';
import { buildSlugMap } from '../../utils/slugs';
import { subcategories, getSubcategoryLabel } from '../../utils/subcategories';
import { categories } from '../../utils/categories';

export function getStaticPaths() {
  return subcategories.dev.map((sub) => ({
    params: { subcategory: sub.slug },
  }));
}

const category = 'dev' as const;

const { subcategory } = Astro.params;
const subLabel = getSubcategoryLabel(category, subcategory!)!;
const catLabel = categories[category].label;

const allPosts = (await getCollection('posts')).filter((p) => !p.data.draft);
const slugMap = buildSlugMap(allPosts);
const posts = allPosts
  .filter((p) => p.data.category === category && p.data.subcategory === subcategory)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title={`${subLabel} - ${catLabel} - Ethan's Blog`} description={`${catLabel} > ${subLabel}`}>
  <h1 class="text-3xl font-bold mb-2">💻 {catLabel}</h1>
  <p class="text-(--color-text-secondary) mb-4">{subLabel} · {posts.length}편</p>
  <SubcategoryNav category={category} current={subcategory} />
  {posts.length === 0 ? (
    <p class="text-(--color-text-secondary)">아직 글이 없습니다.</p>
  ) : (
    <div class="space-y-4">
      {posts.map((post) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          category={post.data.category}
          subcategory={post.data.subcategory}
          pubDate={post.data.pubDate}
          tags={post.data.tags}
          slug={slugMap.get(post.id)!}
          body={post.body}
          heroImage={post.data.heroImage}
        />
      ))}
    </div>
  )}
</BaseLayout>
