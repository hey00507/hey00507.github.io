---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import SubcategoryNav from '../../components/SubcategoryNav.astro';
import { getCollection } from 'astro:content';
import { buildSlugMap } from '../../utils/slugs';

const allPosts = (await getCollection('posts')).filter((p) => !p.data.draft);
const slugMap = buildSlugMap(allPosts);
const posts = allPosts
  .filter((p) => p.data.category === 'dev')
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// 시리즈별 그룹핑
const seriesMap = new Map<string, typeof posts>();
const standalonePosts: typeof posts = [];
for (const post of posts) {
  if (post.data.series) {
    const s = post.data.series;
    if (!seriesMap.has(s)) seriesMap.set(s, []);
    seriesMap.get(s)!.push(post);
  } else {
    standalonePosts.push(post);
  }
}
// 시리즈 내부는 pubDate 오름차순
for (const [, sp] of seriesMap) {
  sp.sort((a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf());
}
---

<BaseLayout title="코딩 - Ethan's Blog" description="기술 학습, 개발 경험, 트러블슈팅">
  <h1 class="text-3xl font-bold mb-2">💻 코딩</h1>
  <p class="text-(--color-text-secondary) mb-4">기술 학습, 개발 경험, 트러블슈팅</p>
  <SubcategoryNav category="dev" />

  {posts.length === 0 ? (
    <p class="text-(--color-text-secondary)">아직 글이 없습니다.</p>
  ) : (
    <>
      {/* 시리즈 섹션 */}
      {seriesMap.size > 0 && (
        <section class="mb-10">
          <h2 class="text-lg font-bold mb-4">📂 시리즈</h2>
          <div class="space-y-3">
            {[...seriesMap.entries()].map(([name, seriesPosts]) => (
              <a href={`/dev/series/${encodeURIComponent(name)}/`} class="group block p-4 rounded-xl border border-(--color-border) hover:border-(--color-accent-dev) transition-colors">
                <div class="flex items-center justify-between">
                  <div>
                    <h3 class="font-semibold group-hover:text-(--color-accent-dev) transition-colors">{name}</h3>
                    <p class="text-sm text-(--color-text-secondary) mt-0.5">{seriesPosts.length}편 · 최근: {seriesPosts[seriesPosts.length - 1].data.title}</p>
                  </div>
                  <span class="text-(--color-text-secondary) group-hover:text-(--color-accent-dev) transition-colors">→</span>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}

      {/* 전체 글 목록 */}
      <section>
        {seriesMap.size > 0 && <h2 class="text-lg font-bold mb-4">📝 전체 글</h2>}
        <div class="space-y-4">
          {posts.map((post) => (
            <PostCard
              title={post.data.title}
              description={post.data.description}
              category={post.data.category}
              subcategory={post.data.subcategory}
              pubDate={post.data.pubDate}
              tags={post.data.tags}
              slug={slugMap.get(post.id)!}
              body={post.body}
          heroImage={post.data.heroImage}
            />
          ))}
        </div>
      </section>
    </>
  )}
</BaseLayout>
