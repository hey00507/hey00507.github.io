---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';
import { getPublishedPosts } from '../../utils/posts';
import { buildSlugMap } from '../../utils/slugs';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const slugMap = buildSlugMap(posts);
  const tags = new Set<string>();
  for (const post of posts) {
    for (const tag of post.data.tags) tags.add(tag);
  }
  return [...tags].map((tag) => ({
    params: { tag },
    props: {
      slugMap: Object.fromEntries(slugMap),
      posts: posts
        .filter((p) => p.data.tags.includes(tag))
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { tag } = Astro.params;
const { posts, slugMap } = Astro.props;
---

<BaseLayout title={`#${tag} - Ethan's Blog`} description={`#${tag} 태그가 포함된 ${posts.length}개의 글`}>
  <script type="application/ld+json" set:html={JSON.stringify({ '@context': 'https://schema.org', '@type': 'CollectionPage', name: `#${tag}`, description: `#${tag} 태그가 포함된 ${posts.length}개의 글`, url: `${Astro.site}tags/${tag}/`, mainEntity: { '@type': 'ItemList', numberOfItems: posts.length } })} slot="head" />
  <div class="mb-8">
    <a href="/tags/" class="text-sm text-(--color-text-secondary) hover:text-(--color-text) transition-colors">← 전체 태그</a>
    <h1 class="text-3xl font-bold mt-2">#{tag}</h1>
    <p class="text-(--color-text-secondary)">{posts.length}개의 글</p>
  </div>
  <div class="space-y-4">
    {posts.map((post) => (
      <PostCard
        title={post.data.title}
        description={post.data.description}
        category={post.data.category}
        subcategory={post.data.subcategory}
        pubDate={post.data.pubDate}
        tags={post.data.tags}
        slug={slugMap[post.id]}
        body={post.body}
          heroImage={post.data.heroImage}
        bookTitle={post.data.bookTitle}
        bookAuthor={post.data.bookAuthor}
        rating={post.data.rating}
      />
    ))}
  </div>
</BaseLayout>
