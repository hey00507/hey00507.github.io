---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getPublishedPosts } from '../../utils/posts';

const posts = await getPublishedPosts();
const tagMap = new Map<string, number>();
for (const post of posts) {
  for (const tag of post.data.tags) {
    tagMap.set(tag, (tagMap.get(tag) || 0) + 1);
  }
}
const tags = [...tagMap.entries()].sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="태그 - Ethan's Blog" description={`${tags.length}개 태그로 분류된 블로그 글 모음`}>
  <script type="application/ld+json" set:html={JSON.stringify({ '@context': 'https://schema.org', '@type': 'CollectionPage', name: '태그', description: `${tags.length}개 태그로 분류된 블로그 글 모음`, url: `${Astro.site}tags/` })} slot="head" />
  <h1 class="text-3xl font-bold mb-8">🏷️ 태그</h1>
  <div class="flex flex-wrap gap-2">
    {tags.map(([tag, count]) => (
      <a
        href={`/tags/${tag}/`}
        class="px-3 py-1.5 rounded-lg bg-(--color-bg-secondary) text-(--color-text-secondary) hover:text-(--color-text) border border-(--color-border) hover:border-(--color-text-secondary) transition-colors text-sm"
      >
        #{tag} <span class="text-xs opacity-60">({count})</span>
      </a>
    ))}
  </div>
</BaseLayout>
