---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import SubcategoryNav from '../../components/SubcategoryNav.astro';
import { getCollection } from 'astro:content';
import { buildSlugMap } from '../../utils/slugs';

const allPosts = (await getCollection('posts')).filter((p) => !p.data.draft);
const slugMap = buildSlugMap(allPosts);
const posts = allPosts
  .filter((p) => p.data.category === 'essay')
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="일상 - Ethan's Blog" description="일상 기록, 생각 정리, 에세이">
  <h1 class="text-3xl font-bold mb-2">✍️ 일상</h1>
  <p class="text-(--color-text-secondary) mb-4">일상 기록, 생각 정리, 에세이</p>
  <SubcategoryNav category="essay" />
  {posts.length === 0 ? (
    <p class="text-(--color-text-secondary)">아직 글이 없습니다.</p>
  ) : (
    <div class="space-y-4">
      {posts.map((post) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          category={post.data.category}
          subcategory={post.data.subcategory}
          pubDate={post.data.pubDate}
          tags={post.data.tags}
          slug={slugMap.get(post.id)!}
          body={post.body}
          heroImage={post.data.heroImage}
        />
      ))}
    </div>
  )}
</BaseLayout>
