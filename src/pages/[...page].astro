---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';
import { getPublishedPosts } from '../utils/posts';
import { buildSlugMap } from '../utils/slugs';

export const getStaticPaths = (async ({ paginate }) => {
  const allPosts = await getPublishedPosts();
  const slugMap = buildSlugMap(allPosts);
  const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
  return paginate(posts, {
    pageSize: 10,
    props: { slugMap: Object.fromEntries(slugMap) },
  });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const slugMap = Astro.props.slugMap as Record<string, string>;
---

<BaseLayout title={page.currentPage === 1 ? "Ethan's Blog" : `Ethan's Blog - ${page.currentPage}페이지`} description={page.currentPage === 1 ? '독서, 일상, 코딩에 대한 기록' : `${page.currentPage}페이지 - 최신 글 목록`}>
  {page.url.prev && <link rel="prev" href={new URL(page.url.prev, Astro.site).href} slot="head" />}
  {page.url.next && <link rel="next" href={new URL(page.url.next, Astro.site).href} slot="head" />}
  <h1 class="text-3xl font-bold mb-2">Blog</h1>
  <p class="text-(--color-text-secondary) mb-8">독서, 일상, 코딩에 대한 기록</p>
  <div class="space-y-4">
    {page.data.map((post) => (
      <PostCard
        title={post.data.title}
        description={post.data.description}
        category={post.data.category}
        subcategory={post.data.subcategory}
        pubDate={post.data.pubDate}
        tags={post.data.tags}
        slug={slugMap[post.id]}
        body={post.body}
        heroImage={post.data.heroImage}
        bookTitle={post.data.bookTitle}
        bookAuthor={post.data.bookAuthor}
        rating={post.data.rating}
      />
    ))}
  </div>

  {/* 페이지네이션 */}
  {page.lastPage > 1 && (
    <nav class="flex items-center justify-center gap-2 mt-10" aria-label="페이지네이션">
      {page.url.prev ? (
        <a href={page.url.prev} class="px-3 py-2 rounded-lg border border-(--color-border) text-sm text-(--color-text-secondary) hover:text-(--color-text) hover:border-(--color-text-secondary) transition-colors">
          ← 이전
        </a>
      ) : (
        <span class="px-3 py-2 rounded-lg text-sm text-(--color-text-secondary) opacity-30">← 이전</span>
      )}

      {Array.from({ length: page.lastPage }, (_, i) => i + 1).map((num) => (
        <a
          href={num === 1 ? '/' : `/${num}/`}
          class:list={[
            'w-9 h-9 flex items-center justify-center rounded-lg text-sm font-medium transition-colors',
            num === page.currentPage
              ? 'bg-(--color-accent-dev) text-white'
              : 'border border-(--color-border) text-(--color-text-secondary) hover:text-(--color-text) hover:border-(--color-text-secondary)',
          ]}
        >
          {num}
        </a>
      ))}

      {page.url.next ? (
        <a href={page.url.next} class="px-3 py-2 rounded-lg border border-(--color-border) text-sm text-(--color-text-secondary) hover:text-(--color-text) hover:border-(--color-text-secondary) transition-colors">
          다음 →
        </a>
      ) : (
        <span class="px-3 py-2 rounded-lg text-sm text-(--color-text-secondary) opacity-30">다음 →</span>
      )}
    </nav>
  )}
</BaseLayout>
