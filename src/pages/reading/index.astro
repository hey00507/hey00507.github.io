---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import SubcategoryNav from '../../components/SubcategoryNav.astro';
import { getCollection } from 'astro:content';
import { buildSlugMap } from '../../utils/slugs';

const allPosts = (await getCollection('posts')).filter((p) => !p.data.draft);
const slugMap = buildSlugMap(allPosts);
const posts = allPosts
  .filter((p) => p.data.category === 'reading')
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="독서 - Ethan's Blog" description="책 리뷰, 독후감, 인상 깊은 구절">
  <div class="flex items-center justify-between mb-2">
    <h1 class="text-3xl font-bold">📖 독서</h1>
    <a href="/reading/dashboard/" class="text-sm px-3 py-1.5 rounded-lg bg-(--color-bg-secondary) border border-(--color-border) text-(--color-text-secondary) hover:text-(--color-accent-reading) hover:border-(--color-accent-reading) transition-colors">
      📊 대시보드
    </a>
  </div>
  <p class="text-(--color-text-secondary) mb-4">책 리뷰, 독후감, 인상 깊은 구절</p>
  <SubcategoryNav category="reading" />
  {posts.length === 0 ? (
    <p class="text-(--color-text-secondary)">아직 글이 없습니다.</p>
  ) : (
    <div class="space-y-4">
      {posts.map((post) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          category={post.data.category}
          subcategory={post.data.subcategory}
          pubDate={post.data.pubDate}
          tags={post.data.tags}
          slug={slugMap.get(post.id)!}
          body={post.body}
          heroImage={post.data.heroImage}
          bookTitle={post.data.bookTitle}
          bookAuthor={post.data.bookAuthor}
          rating={post.data.rating}
        />
      ))}
    </div>
  )}
</BaseLayout>
